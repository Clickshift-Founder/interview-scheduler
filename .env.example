# Copy this to Vercel → Project → Settings → Environment Variables
# NEVER commit real values to GitHub

# Airtable (your Personal Access Token from airtable.com → Account → Developer hub)
AIRTABLE_PAT=pat_xxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# EmailJS (from emailjs.com → Account → API Keys)
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxx
EMAILJS_PRIVATE_KEY=xxxxxxxxxxxxxxxxx
